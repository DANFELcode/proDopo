comment0.target=Thing
comment0.text=\n\ Thing\n\ Representa\ la\ interfaz\ base\ para\ todos\ los\ elementos\ que\ pueden\ existir\ \n\ dentro\ de\ la\ cuadr\u00EDcula\ del\ bosque.\n
comment1.params=
